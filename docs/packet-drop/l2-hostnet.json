  "panels": [
    {
      "type": "row",
      "collapsed": false,
      "title": "🎯 핵심 — pod drop(stack) vs node interface drop(기준선)  ※ nodename 1개만 선택",
      "id": 1,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RX: per-pod drop STACK + node iface 기준선",
      "description": "**파드별 RX drop을 누적(stack)**하고 그 위에 **노드 인터페이스 RX drop을 빨간 점선 기준선**으로. hostNetwork 파드(csi-nfs·node-exporter)는 host netns를 공유해 cAdvisor가 노드 인터페이스 카운터를 그대로 보고 → 각 파드 밴드가 **같은 패턴으로 움직이며 기준선과 일치**하면 'drop은 노드 인터페이스에서 발생, 파드는 중복 반영'이 증명됨. (hostNetwork 파드 N개면 stack은 기준선의 N배로 과대 — 패턴 일치 확인용)\\n어느 구간에서 솟는지 = x축으로 바로 보임.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "maxDataPoints": 600,
      "interval": "30s",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by(pod)(rate(container_network_receive_packets_dropped_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(node_network_receive_drop_total{cluster=\"$cluster\",project=\"$project\",instance=~\"$instance\",device=~\"$device\"}[$__rate_interval]) * on(instance) group_left() node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"})",
          "legendFormat": "▶ node iface RX drop (기준선)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 28,
            "showPoints": "never",
            "spanNulls": false,
            "lineInterpolation": "linear",
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "dashed"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "▶ node iface RX drop (기준선)"
            },
            "properties": [
              {
                "id": "custom.stacking",
                "value": {
                  "group": "B",
                  "mode": "none"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 3
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    8,
                    4
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "max",
            "lastNotNull"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
