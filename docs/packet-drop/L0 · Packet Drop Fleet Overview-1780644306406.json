{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0,211,255,1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Fleet 진입점(저부하): state-timeline+topk로 어느 노드/pod가 빨간지 한 화면에. cross-node는 여기뿐(단일 topk). 빨간 노드/pod 클릭 → ${__field.labels.*}로 상세 드릴다운. recording-rules.yml 적용 시 instant.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": 66,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "pktdrop"
      ],
      "targetBlank": false,
      "title": "Packet Drop",
      "type": "dashboards"
    },
    {
      "icon": "arrow-up",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
      "title": "↑ L1 Node",
      "type": "link",
      "url": "/d/pktdrop-l1-node?${__url_time_range}&var-cluster=${cluster}&var-project=${project}"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "🛰️ Fleet — 어느 노드가 언제 빨간가 (한 화면, 클릭 드릴다운)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "per-node RX drop을 임계 색상으로(state timeline). 전 노드를 한 화면에서 보고 빨간 노드/구간을 바로 식별 → 칸 클릭 시 ${__field.labels.nodename}로 L1 드릴다운. 단일 topk 쿼리(패널 fan-out 없음). recording rule `nodename:net_rx_drop:sum_rate5m` 적용 시 더 저렴.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "fillOpacity": 80,
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineWidth": 0,
            "spanNulls": false
          },
          "links": [
            {
              "targetBlank": false,
              "title": "드릴다운 → L1 Node",
              "url": "/d/pktdrop-l1-node?${__url_time_range}&var-cluster=${cluster}&var-project=${project}&var-nodename=${__field.labels.nodename}"
            }
          ],
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "pps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "maxDataPoints": 300,
      "options": {
        "alignValue": "left",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "mergeValues": false,
        "rowHeight": 0.9,
        "showValue": "never",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(30, sum by(nodename)(rate(node_network_receive_drop_total{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) node_uname_info{cluster=\"$cluster\",project=\"$project\"}))",
          "instant": false,
          "legendFormat": "{{nodename}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "노드별 RX drop 상태(시간) — 빨간 칸 클릭 → L1",
      "type": "state-timeline"
    },
    {
