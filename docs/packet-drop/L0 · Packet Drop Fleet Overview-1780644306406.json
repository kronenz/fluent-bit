          "expr": "topk(25, sum by(nodename)((rate(node_network_receive_drop_total{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) node_uname_info{cluster=\"$cluster\",project=\"$project\"}) or (rate(node_softnet_dropped_total{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) node_uname_info{cluster=\"$cluster\",project=\"$project\"}) or label_replace(rate(container_network_receive_packets_dropped_total{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]), \"nodename\", \"$1\", \"node\", \"(.+)\")))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Top nodes by drop (NIC+softnet+pod)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "drop pps(합)"
            }
          }
        }
      ],
      "type": "table"
    },
