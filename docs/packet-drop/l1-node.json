project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))*100)/25)[$__range:1m]), \"cause\", \"② softirq 포화 → IRQ affinity/RPS\", \"__name__\", \".*\") or label_replace(max_over_time(((sum(rate(node_netstat_Udp_RcvbufErrors{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))+sum(rate(node_netstat_TcpExt_TCPBacklogDrop{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))+sum(rate(node_netstat_TcpExt_ListenOverflows{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"})))/5)[$__range:1m]), \"cause\", \"② socket 큐 (executor recv 부족) → rmem_max/somaxconn↑\", \"__name__\", \".*\") or label_replace(max_over_time(((sum(rate(node_netstat_Tcp_RetransSegs{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))/clamp_min(sum(rate(node_netstat_Tcp_OutSegs{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"})),1))/0.01)[$__range:1m]), \"cause\", \"경로 혼잡 (TCP retrans ratio)\", \"__name__\", \".*\") or label_replace(max_over_time((sum(rate(cilium_drop_count_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",reason!~\"$cilium_drop_exclude_reason\"}[$__rate_interval]))/100)[$__range:1m]), \"cause\", \"③ cilium datapath drop\", \"__name__\", \".*\") or label_replace(max_over_time((max(cilium_bpf_map_pressure{cluster=\"$cluster\",project=\"$project\",map_name=~\".*ct.*|.*nat.*\"})/0.95)[$__range:1m]), \"cause\", \"③ cilium CT/NAT 맵 포화 → bpf-ct/nat-global-max↑\", \"__name__\", \".*\") or label_replace(max_over_time((sum(rate(cilium_drop_count_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",reason!~\"$cilium_drop_exclude_reason\",reason=~\".*[Pp]olicy.*\"}[$__rate_interval]))/10)[$__range:1m]), \"cause\", \"③ cilium Policy denied → 정책 허용\", \"__name__\", \".*\") or label_replace(max_over_time((sum(rate(container_network_receive_packets_dropped_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))/10)[$__range:1m]), \"cause\", \"④ pod veth drop\", \"__name__\", \".*\") or label_replace(max_over_time((max(sum by(namespace,pod)(rate(container_cpu_cfs_throttled_periods_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))/clamp_min(sum by(namespace,pod)(rate(container_cpu_cfs_periods_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])),1))/0.5)[$__range:1m]), \"cause\", \"④ pod CPU throttle → limit↑\", \"__name__\", \".*\")",
