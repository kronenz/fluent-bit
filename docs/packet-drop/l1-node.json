        "y": 0
      },
      "panels": []
    },
    {
      "id": 11,
      "type": "stat",
      "title": "🧭 추정 원인 (top severity)",
      "description": "각 계층 drop 신호를 자기 임계값으로 정규화한 severity = 현재값/임계값. **>1 이면 임계 초과**, 값이 클수록 원인일 확률↑. 여러 계층이 동시에 빨개도 가장 높은 것이 1차 용의자. PromQL 한 번으로 NIC/커널/cilium/pod 전 계층을 비교한다.\\nseverity는 단위 무관 비교용(예: 1.4=임계의 1.4배). 각 원인 라벨 끝에 1차 조치 힌트 포함.\\n**선택한 시간범위(start~end)의 peak** 기준(max_over_time[$__range]). '지금' 값이 아니라 범위 전체에서 가장 나빴던 값.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(1, label_replace(max_over_time((sum(rate(node_network_receive_fifo_total{cluster=\"$cluster\",project=\"$project\",instance=~\"$instance\",device=~\"$device\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))/1)[$__range:1m]), \"cause\", \"① NIC ring overrun (fifo) → ethtool -G rx↑\", \"__name__\", \".*\") or label_replace(max_over_time((sum(rate(node_network_receive_drop_total{cluster=\"$cluster\",project=\"$project\",instance=~\"$instance\",device=~\"$device\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))/100)[$__range:1m]), \"cause\", \"① NIC RX drop (IRQ/ring)\", \"__name__\", \".*\") or label_replace(max_over_time((max((node_nf_conntrack_entries{cluster=\"$cluster\",project=\"$project\"}/node_nf_conntrack_entries_limit{cluster=\"$cluster\",project=\"$project\"}) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))/0.9)[$__range:1m]), \"cause\", \"① conntrack 고갈(node) → nf_conntrack_max↑\", \"__name__\", \".*\") or label_replace(max_over_time((sum(rate(node_softnet_dropped_total{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))/10)[$__range:1m]), \"cause\", \"② softnet backlog → netdev_max_backlog↑\", \"__name__\", \".*\") or label_replace(max_over_time((max(sum by(nodename)(rate(node_cpu_seconds_total{cluster=\"$cluster\",project=\"$project\",mode=\"softirq\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))/sum by(nodename)(rate(node_cpu_seconds_total{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))*100)/25)[$__range:1m]), \"cause\", \"② softirq 포화 → IRQ affinity/RPS\", \"__name__\", \".*\") or label_replace(max_over_time(((sum(rate(node_netstat_Udp_RcvbufErrors{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))+sum(rate(node_netstat_TcpExt_TCPBacklogDrop{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))+sum(rate(node_netstat_TcpExt_ListenOverflows{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"})))/5)[$__range:1m]), \"cause\", \"② socket 큐 (executor recv 부족) → rmem_max/somaxconn↑\", \"__name__\", \".*\") or label_replace(max_over_time(((sum(rate(node_netstat_Tcp_RetransSegs{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))/clamp_min(sum(rate(node_netstat_Tcp_OutSegs{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left(nodename) topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"})),1))/0.01)[$__range:1m]), \"cause\", \"경로 혼잡 (TCP retrans ratio)\", \"__name__\", \".*\") or label_replace(max_over_time((sum(rate(cilium_drop_count_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",reason!~\"$cilium_drop_exclude_reason\"}[$__rate_interval]))/100)[$__range:1m]), \"cause\", \"③ cilium datapath drop\", \"__name__\", \".*\") or label_replace(max_over_time((max(cilium_bpf_map_pressure{cluster=\"$cluster\",project=\"$project\",map_name=~\".*ct.*|.*nat.*\"})/0.95)[$__range:1m]), \"cause\", \"③ cilium CT/NAT 맵 포화 → bpf-ct/nat-global-max↑\", \"__name__\", \".*\") or label_replace(max_over_time((sum(rate(cilium_drop_count_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",reason!~\"$cilium_drop_exclude_reason\",reason=~\".*[Pp]olicy.*\"}[$__rate_interval]))/10)[$__range:1m]), \"cause\", \"③ cilium Policy denied → 정책 허용\", \"__name__\", \".*\") or label_replace(max_over_time((sum(rate(container_network_receive_packets_dropped_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))/10)[$__range:1m]), \"cause\", \"④ pod veth drop\", \"__name__\", \".*\") or label_replace(max_over_time((max(sum by(namespace,pod)(rate(container_cpu_cfs_throttled_periods_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval]))/clamp_min(sum by(namespace,pod)(rate(container_cpu_cfs_periods_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",namespace=~\"$namespace\",pod=~\"$pod\"}[$__rate_interval])),1))/0.5)[$__range:1m]), \"cause\", \"④ pod CPU throttle → limit↑\", \"__name__\", \".*\"))",
          "legendFormat": "{{cause}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        }
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "📊 원인 스코어보드 (severity 내림차순)",
      "description": "각 계층 drop 신호를 자기 임계값으로 정규화한 severity = 현재값/임계값. **>1 이면 임계 초과**, 값이 클수록 원인일 확률↑. 여러 계층이 동시에 빨개도 가장 높은 것이 1차 용의자. PromQL 한 번으로 NIC/커널/cilium/pod 전 계층을 비교한다.\\nseverity는 단위 무관 비교용(예: 1.4=임계의 1.4배). 각 원인 라벨 끝에 1차 조치 힌트 포함.\\n**선택한 시간범위(start~end)의 peak** 기준(max_over_time[$__range]). '지금' 값이 아니라 범위 전체에서 가장 나빴던 값.",
      "datasource": {
