          "expr": "sum(increase(container_network_receive_packets_dropped_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",namespace=~\"$namespace\",pod=~\"$pod\"}[$__range])) / clamp_min(sum(increase(container_network_receive_packets_total{cluster=\"$cluster\",project=\"$project\",node=~\"$nodename\",namespace=~\"$namespace\",pod=~\"$pod\"}[$__range])),1) * 100",
          "legendFormat": "★ RX drop 비율 %",
          "refId": "A",
          "instant": true
        }
