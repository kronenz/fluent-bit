 "timezone": "",
 "annotations": {
  "list": [
   {
    "builtIn": 1,
    "type": "dashboard",
    "name": "Annotations & Alerts",
    "datasource": {
     "type": "grafana",
     "uid": "-- Grafana --"
    },
    "iconColor": "rgba(0,211,255,1)",
    "enable": true,
    "hide": true
   },
   {
    "name": "① retrans>2%",
    "datasource": {
     "type": "prometheus",
     "uid": "${datasource}"
    },
    "enable": false,
    "hide": false,
    "iconColor": "purple",
    "expr": "(sum(rate(node_netstat_Tcp_RetransSegs{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left() topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"})) / clamp_min(sum(rate(node_netstat_Tcp_OutSegs{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left() topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"})), 1)) > bool 0.02 == 1",
    "step": "60s",
    "titleFormat": "retrans ratio > 2%"
   },
   {
    "name": "③ rx_drop>0",
    "datasource": {
     "type": "prometheus",
     "uid": "${datasource}"
    },
    "enable": false,
    "hide": false,
    "iconColor": "red",
    "expr": "(sum(rate(node_network_receive_drop_total{cluster=\"$cluster\",project=\"$project\"}[$__rate_interval]) * on(instance) group_left() topk by(instance)(1, node_uname_info{cluster=\"$cluster\",project=\"$project\",nodename=~\"$nodename\"}))) > bool 0 == 1",
    "step": "60s",
    "titleFormat": "rx drop 발생"
   },
   {
    "name": "AIStor 불균형>2",
    "datasource": {
     "type": "prometheus",
     "uid": "${datasource}"
    },
    "enable": false,
    "hide": false,
    "iconColor": "orange",
    "expr": "(max(sum by (nodename) (rate(node_network_receive_bytes_total{cluster=\"$aistor_cluster\"}[$__rate_interval]) * 8 * on(instance) group_left(nodename) node_uname_info{cluster=\"$aistor_cluster\"})) / clamp_min(avg(sum by (nodename) (rate(node_network_receive_bytes_total{cluster=\"$aistor_cluster\"}[$__rate_interval]) * 8 * on(instance) group_left(nodename) node_uname_info{cluster=\"$aistor_cluster\"})),1)) > bool 2 == 1",
    "step": "60s",
    "titleFormat": "AIStor 인입 불균형 > 2x"
   }
  ]
 },
