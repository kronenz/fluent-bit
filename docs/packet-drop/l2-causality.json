   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "justifyMode": "center",
    "textMode": "value_and_name",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ],
     "fields": "",
     "values": false
    }
   }
  },
  {
   "id": 5,
   "type": "stat",
   "title": "③ RX drop",
