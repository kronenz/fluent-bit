      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background_solid", "graphMode": "area", "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(node_netstat_TcpExt_TCPDSACKRecv{cluster=\"icdataops-prd\"}[$__rate_interval])) / clamp_min(sum(rate(node_netstat_Tcp_RetransSegs{cluster=\"icdataops-prd\"}[$__rate_interval])),1)",
          "legendFormat": "dsack/retrans",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "type": "row",
      "title": "ВЮИЖ│╝ ВѓгВіг ВѕюВ░е ьїевёљ (Вюё Рєњ ВЋёвъў = ВІюЖ░ё ВёаьЏё Ж┤ђЖ│ё)",
