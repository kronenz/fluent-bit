    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "name": "РЉа Retransmit Spike",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "enable": true,
        "iconColor": "super-light-purple",
        "hide": false,
        "target": {
          "expr": "(rate(node_netstat_Tcp_RetransSegs{cluster=\"icdataops-prd\"}[1m]) / clamp_min(rate(node_netstat_Tcp_OutSegs{cluster=\"icdataops-prd\"}[1m]),1)) > 0.02",
          "refId": "RetransAnno"
        },
        "useValueForTime": false,
        "iconSize": 14,
        "tagKeys": "instance",
        "textFormat": "Retrans ratio > 2% Рђћ ВЮИЖ│╝ ВІюВъЉВаљ(РЉа)"
      },
      {
        "name": "РЉб RX Drop Onset",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "enable": true,
        "iconColor": "red",
        "hide": false,
        "target": {
          "expr": "rate(node_network_receive_drop_total{cluster=\"icdataops-prd\"}[1m]) > 0",
          "refId": "DropAnno"
        },
        "tagKeys": "instance,device",
        "textFormat": "RX drop в░юВЃЮ(РЉб) Рђћ ВЮИЖ│╝ ВѓгВігВЮў ВхюВбЁ Ж▓░Ж│╝"
      }
    ]
  },
  "description": "ьі╣ВаЋ в╣ЁвЇ░ВЮ┤ьё░ Вёюв╣ёВіцВЮў AIStor(storage-cluster) ВаЉЖи╝ ВІю в░юВЃЮьЋўвіћ TCP ВъгВаёВєА ВДЉВцЉВЮ┤ NAPI squeeze в░Ј RX dropВю╝вАю ВЮ┤Вќ┤ВДђвіћ ВІюЖ░ёВѕю ВЮИЖ│╝Ж┤ђЖ│ё(РЉаРєњРЉАРєњРЉб)вЦ╝ ВъЁВдЮьЋўЖИ░ ВюёьЋю вїђВІюв│┤вЊю. вфевЊа ВІюЖ│ёВЌ┤ ьїевёљВЮђ Ж│хВюа crosshair/tooltip в░Ј вЈЎВЮ╝ ВІюЖ░ёВХЋВю╝вАю ВаЋвагвљўВќ┤ ьїевёљ Ж░ё ВёаьЏё ВЃЂЖ┤ђЖ┤ђЖ│ёвЦ╝ ьЋю ьЎћвЕ┤ВЌљВёю Ж▓ђВдЮьЋа Вѕў ВъѕвЈёвАЮ ЖхгВё▒вље.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "tags": [],
      "targetBlank": true,
      "title": "Topology / ВЮИЖ│╝ вЕћВ╗цвІѕВдў ВёцвфЁ",
      "type": "link",
      "url": "#"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "text",
      "title": "ВЮИЖ│╝ Ж░ђВёц ┬и Ж▓ђВдЮ Ж┤ђВаљ",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "options": {
        "mode": "markdown",
        "content": "## ­ЪЊѕ ВЮИЖ│╝ ВѓгВіг Ж▓ђВдЮ: РЉа TCP Retransmit Рєњ РЉА NAPI Squeeze Рєњ РЉб RX Drop\n**Ж░ђВёц(ьЋ┤ВёЮ A):** ьі╣ВаЋ в╣ЁвЇ░ВЮ┤ьё░ Вёюв╣ёВіцВЮў `storage-cluster`(AIStor) ВДЉВцЉ ВаЉЖи╝ Рєњ flow ВДЉВцЉВЌљ ВЮўьЋю ВДђВЌ░/ВДђьё░ Рєњ **ВА░ЖИ░ ВъгВаёВєА(РЉа)** Рєњ ВцЉв│х ьіИвъўьћй вѕёВаЂ Рєњ **NAPI budget ВєїВДё/squeeze(РЉА)** Рєњ ring overflow Рєњ **RX Drop(РЉб)**.  \n**Ж▓ђВдЮ в░Ев▓Ћ:** вфевЊа ьїевёљВЮђ *вЈЎВЮ╝ ВІюЖ░ёВХЋ + Ж│хВюа crosshair(Shared crosshair)* вАю ВаЋвагвље. вДѕВџ░ВіцвЦ╝ ьЋю ьїевёљВЌљ ВўгвдгвЕ┤ Ваё ьїевёљВЌљ вЈЎВЮ╝ ВІюВаљ ВѕўВДЂВёаВЮ┤ ьЉюВІювљўВќ┤ **РЉаРєњРЉАРєњРЉбВЮў ВёаьЏёЖ┤ђЖ│ё**вЦ╝ вѕѕВю╝вАю ьЎЋВЮИ Ж░ђвіЦ. в│┤вЮ╝ВЃЅ/в╣еЖ░Ћ annotationВЮ┤ РЉа┬иРЉб в░юВЃЮ ВІюВаљВЮё ВъљвЈЎ ьЉюЖИ░.  \n`icdataops-prd` = DataOps(ВѕўВІа┬ивЊювАГ ВИА) ┬и `storage-cluster` = AIStor S3(ВъгВаёВєА Вюав░ю hotspot ВИА)"
      }
    },

    {
      "type": "stat",
      "title": "РЉа Retrans Ratio (icdataops-prd)",
      "description": "ВъгВаёВєА ВёИЖиИве╝ьіИ / ВаёВ▓┤ ВєАВІа ВёИЖиИве╝ьіИ в╣ёВюе. ВЮИЖ│╝ ВѓгВігВЮў 1В░е ьіИвдгЖ▒░ ВДђьЉю.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 4 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.02 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(node_netstat_Tcp_RetransSegs{cluster=\"icdataops-prd\"}[$__rate_interval])) / clamp_min(sum(rate(node_netstat_Tcp_OutSegs{cluster=\"icdataops-prd\"}[$__rate_interval])),1)",
          "legendFormat": "retrans ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "РЉА softnet time_squeeze /s",
      "description": "NAPI poll budget ВєїВДё ьџЪВѕў(В┤ѕвІ╣). ВъгВаёВєА вѕёВаЂВю╝вАю ВЮИьЋю В▓ўвдг ВЋЋв░ЋВЮў ВцЉЖ░ё ВДђьЉю.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 4 },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background_solid", "graphMode": "area", "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(node_softnet_times_squeezed_total{cluster=\"icdataops-prd\"}[$__rate_interval]))",
          "legendFormat": "squeeze/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "РЉб RX Drop /s (icdataops-prd)",
      "description": "ВѕўВІа ring overflowвАю ьЈљЖИ░вљю ьїеьѓи(В┤ѕвІ╣). ВЮИЖ│╝ ВѓгВігВЮў ВхюВбЁ Ж▓░Ж│╝ ВДђьЉю.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 4 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "decimals": 1,
