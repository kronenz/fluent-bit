      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(node_network_receive_drop_total{cluster=\"icdataops-prd\"}[$__rate_interval]))",
          "legendFormat": "rx_drop/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Spurious ВЮўВІгвЈё (DSACK/Retrans)",
      "description": "DSACK ВѕўВІа в╣ёВюеВЮ┤ вєњВЮёВѕўвАЮ 'ьЋёВџћ ВЌєвЇў ВъгВаёВєА(spurious)'ВЮ╝ Ж░ђвіЦВё▒РєЉ Рєњ ьЋ┤ВёЮ A(ВДђВЌ░/ВДђьё░ ЖИ░в░ў ВА░ЖИ░ ВъгВаёВєА) Жи╝Ж▒░.",
