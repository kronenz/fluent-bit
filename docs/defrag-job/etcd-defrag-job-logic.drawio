<mxCell id="n41" value="조건식 (개선 수식과 동일)&#10;  in_use/total &lt; 0.5  AND  total/quota &gt; 0.5  AND  in_use &gt; 800Mi&#10;  또는  total/quota &gt; 0.8  (쿼터 압박 — 즉시)" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fontSize=11;fontColor=#334155;fontStyle=0;spacingLeft=2;" vertex="1" parent="1"><mxGeometry x="78" y="524" width="444" height="70" as="geometry"/></mxCell>
