{
  "__inputs": [
    {
      "name": "DS_OPENSEARCH",
      "label": "OpenSearch",
      "type": "datasource",
      "pluginId": "grafana-opensearch-datasource",
      "pluginName": "OpenSearch"
    },
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "K8s Workload Logs (OpenSearch)",
  "uid": "k8s-workload-logs",
  "tags": ["logs", "opensearch", "kubernetes", "workload"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "ds_opensearch",
        "label": "OpenSearch DS",
        "type": "datasource",
        "query": "grafana-opensearch-datasource",
        "current": {},
        "hide": 0
      },
      {
        "name": "ds_prometheus",
        "label": "Prometheus DS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
        "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel, namespace)",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {}
      },
      {
        "name": "workload_type",
        "label": "Workload Type",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
        "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=~\"$namespace\"}, workload_type)",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "current": {}
      },
      {
        "name": "workload",
        "label": "Workload",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
        "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=~\"$namespace\", workload_type=~\"$workload_type\"}, workload)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {}
      },
      {
        "name": "pod",
        "label": "Pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
        "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=~\"$namespace\", workload_type=~\"$workload_type\", workload=~\"$workload\"}, pod)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {}
      },
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
        "query": "{\"find\": \"terms\", \"field\": \"kubernetes.container_name.keyword\", \"query\": \"kubernetes.namespace_name:\\\"$namespace\\\"\"}",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": "*",
        "current": {}
      },
      {
        "name": "level",
        "label": "Level",
        "type": "query",
        "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
        "query": "{\"find\": \"terms\", \"field\": \"level.keyword\"}",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": "*",
        "current": {}
      },
      {
        "name": "keyword",
        "label": "Keyword (Lucene)",
        "type": "textbox",
        "query": "*",
        "current": { "text": "*", "value": "*" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Logs",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
      "targets": [
        {
          "refId": "A",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "query": "kubernetes.namespace_name:\"$namespace\" AND kubernetes.pod_name:(${pod:lucene}) AND kubernetes.container_name:(${container:lucene}) AND level:(${level:lucene}) AND ($keyword)",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": []
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
      "targets": [
        {
          "refId": "A",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "query": "kubernetes.namespace_name:\"$namespace\" AND kubernetes.pod_name:(${pod:lucene}) AND kubernetes.container_name:(${container:lucene}) AND (level:ERROR OR level:error OR level:FATAL) AND ($keyword)",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": []
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Warnings",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
      "targets": [
        {
          "refId": "A",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "query": "kubernetes.namespace_name:\"$namespace\" AND kubernetes.pod_name:(${pod:lucene}) AND kubernetes.container_name:(${container:lucene}) AND (level:WARN OR level:warn OR level:WARNING) AND ($keyword)",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": []
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Pods (selected workload)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (pod) (namespace_workload_pod:kube_pod_owner:relabel{namespace=~\"$namespace\", workload_type=~\"$workload_type\", workload=~\"$workload\"}))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Logs by Level",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
      "targets": [
        {
          "refId": "A",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "query": "kubernetes.namespace_name:\"$namespace\" AND kubernetes.pod_name:(${pod:lucene}) AND kubernetes.container_name:(${container:lucene}) AND level:(${level:lucene}) AND ($keyword)",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "terms", "field": "level.keyword", "settings": { "size": "10", "order": "desc", "orderBy": "_count", "min_doc_count": "1" } }
          ]
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "values": false },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Log Volume by Level",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
      "targets": [
        {
          "refId": "A",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "query": "kubernetes.namespace_name:\"$namespace\" AND kubernetes.pod_name:(${pod:lucene}) AND kubernetes.container_name:(${container:lucene}) AND level:(${level:lucene}) AND ($keyword)",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "3", "type": "terms", "field": "level.keyword", "settings": { "size": "10", "order": "desc", "orderBy": "_count", "min_doc_count": "1" } },
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0", "trimEdges": "0" } }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" }, "lineWidth": 0 },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "(?i).*error.*|.*fatal.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byRegexp", "options": "(?i).*warn.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byRegexp", "options": "(?i).*info.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Log Volume by Pod (Top 10)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
      "targets": [
        {
          "refId": "A",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "query": "kubernetes.namespace_name:\"$namespace\" AND kubernetes.pod_name:(${pod:lucene}) AND kubernetes.container_name:(${container:lucene}) AND level:(${level:lucene}) AND ($keyword)",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "3", "type": "terms", "field": "kubernetes.pod_name.keyword", "settings": { "size": "10", "order": "desc", "orderBy": "_count", "min_doc_count": "1" } },
            { "id": "2", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } }
          ]
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top Pods by Error Count",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
      "targets": [
        {
          "refId": "A",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "query": "kubernetes.namespace_name:\"$namespace\" AND kubernetes.pod_name:(${pod:lucene}) AND kubernetes.container_name:(${container:lucene}) AND (level:ERROR OR level:error OR level:FATAL) AND ($keyword)",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            { "id": "2", "type": "terms", "field": "kubernetes.pod_name.keyword", "settings": { "size": "15", "order": "desc", "orderBy": "_count", "min_doc_count": "1" } }
          ]
        }
      ],
      "transformations": [],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Raw Logs",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "${ds_opensearch}" },
      "targets": [
        {
          "refId": "A",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "query": "kubernetes.namespace_name:\"$namespace\" AND kubernetes.pod_name:(${pod:lucene}) AND kubernetes.container_name:(${container:lucene}) AND level:(${level:lucene}) AND ($keyword)",
          "metrics": [{ "id": "1", "type": "logs", "settings": { "limit": "500" } }],
          "bucketAggs": []
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
