        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Intel E810-XXV 25G NIC RX Packet Drop Diagnostic Dashboard - 카운터 기반 원인 분류",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "📊 Overview - RX Drop 개요",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "현재 RX drop 발생률 (pps)",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 100}
            ]
          },
          "unit": "pps"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(node_network_receive_drop_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval]))",
          "legendFormat": "RX Drops",
          "refId": "A"
        }
      ],
      "title": "RX Drop Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "전체 RX 패킷 대비 drop 비율. 0.001% 이상 주의, 0.01% 이상 위험",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 6,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.001},
              {"color": "red", "value": 0.01}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "100 * (sum(rate(node_network_receive_drop_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval])) / sum(rate(node_network_receive_packets_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval])))",
          "legendFormat": "Drop %",
          "refId": "A"
        }
      ],
      "title": "RX Drop Ratio (%)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "RX 처리량 (pps)",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "pps"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(node_network_receive_packets_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval]))",
          "legendFormat": "RX pps",
          "refId": "A"
        }
      ],
      "title": "RX Throughput",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "RX 대역폭 (bps)",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "bps"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(node_network_receive_bytes_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval])) * 8",
          "legendFormat": "RX bps",
          "refId": "A"
        }
      ],
      "title": "RX Bandwidth",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "시간에 따른 RX drop 추이",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "unit": "pps"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 5},
      "id": 5,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(node_network_receive_drop_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval])",
          "legendFormat": "{{instance}} - {{device}}",
          "refId": "A"
        }
      ],
      "title": "RX Drop Trend (per interface)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 101,
      "panels": [],
      "title": "🔍 NIC Counter 분류 - 원인별 카운터",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "NIC 카운터 종합 - 동시에 움직이는 카운터로 원인 파악\n\n- missed: NIC가 PCIe로 못 올림 (IRQ/호스트 지연)\n- no_buffer: descriptor 부족 (ring/NAPI)\n- fifo: NIC 내부 FIFO overrun (PCIe/IRQ)\n- crc: 물리계층 오류 (광/케이블)\n- length: MTU 불일치\n- frame: 프레이밍 오류",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "unit": "pps"
        }
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 14},
      "id": 6,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(node_ethtool_rx_missed_errors{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval]))",
          "legendFormat": "missed (IRQ/호스트지연)",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(node_ethtool_rx_no_buffer_count{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval]))",
          "legendFormat": "no_buffer (ring/NAPI)",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(node_network_receive_fifo_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval]))",
          "legendFormat": "fifo (PCIe/IRQ)",
          "refId": "C"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(node_network_receive_crc_errors_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval]))",
          "legendFormat": "crc (물리계층)",
          "refId": "D"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(node_network_receive_length_errors_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval]))",
          "legendFormat": "length (MTU)",
          "refId": "E"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(rate(node_network_receive_frame_errors_total{cluster=\"$cluster\", project=\"dataops\", device=~\"$iface\"}[$__rate_interval]))",
          "legendFormat": "frame (프레이밍)",
          "refId": "F"
        }
      ],
      "title": "RX Counter Breakdown - 원인 분류",
      "type": "timeseries"
    },
    {
      "collapsed": false,
