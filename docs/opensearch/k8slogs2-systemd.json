        "datasource": {
          "type": "grafana-opensearch-datasource",
          "uid": "${datasource}"
        },
        "query": "{\"find\": \"terms\", \"field\": \"HOSTNAME.keyword\", \"size\": 100}",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
