     "text": "OpenSearch-logs",
     "value": "os-logs"
    },
    "hide": 0
   },
   {
    "name": "namespace",
    "label": "Namespace",
    "type": "query",
    "datasource": {
     "type": "grafana-opensearch-datasource",
     "uid": "${datasource}"
    },
    "definition": "{\"find\": \"terms\", \"field\": \"kubernetes.namespace_name.keyword\", \"size\": 100}",
    "query": "{\"find\": \"terms\", \"field\": \"kubernetes.namespace_name.keyword\", \"size\": 100}",
    "refresh": 2,
    "sort": 1,
    "multi": true,
    "includeAll": true,
    "allValue": "*",
    "hide": 0,
    "current": {
     "text": "All",
     "value": "$__all"
    },
    "options": []
   },
   {
    "name": "workload_kind",
    "label": "워크로드 종류",
    "type": "query",
    "datasource": {
     "type": "grafana-opensearch-datasource",
     "uid": "${datasource}"
    },
    "definition": "{\"find\": \"terms\", \"field\": \"kubernetes.workload_kind.keyword\", \"size\": 100, \"query\": \"kubernetes.namespace_name.keyword:($namespace)\"}",
    "query": "{\"find\": \"terms\", \"field\": \"kubernetes.workload_kind.keyword\", \"size\": 100, \"query\": \"kubernetes.namespace_name.keyword:($namespace)\"}",
