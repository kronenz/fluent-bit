   "datasource": {
    "type": "grafana-opensearch-datasource",
    "uid": "${datasource}"
   },
   "gridPos": {
    "h": 4,
    "w": 12,
    "x": 12,
    "y": 3
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "grafana-opensearch-datasource",
      "uid": "${datasource}"
     },
     "query": "kubernetes.namespace_name.keyword:($namespace) AND (kubernetes.workload_kind.keyword:($workload_kind)) AND (stream:stderr OR level:(ERROR OR error OR FATAL OR fatal) OR log:(*error* OR *fail* OR *panic*))",
     "queryType": "lucene",
     "timeField": "@timestamp",
     "metrics": [
      {
       "id": "1",
       "type": "count"
      }
     ],
     "bucketAggs": [
      {
       "id": "9",
       "type": "date_histogram",
       "field": "@timestamp",
       "settings": {
        "interval": "auto",
        "min_doc_count": "0",
        "trimEdges": "0"
       }
      }
     ]
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "sum"
     ],
     "fields": "",
     "values": false
    },
    "colorMode": "value",
    "graphMode": "area",
    "orientation": "auto",
    "textMode": "auto",
    "justifyMode": "auto"
