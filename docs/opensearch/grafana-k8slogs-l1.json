 "panels": [
  {
   "type": "text",
   "title": "사용 가이드",
   "gridPos": {
    "h": 3,
    "w": 24,
    "x": 0,
    "y": 0
   },
   "options": {
    "mode": "markdown",
    "content": "워크로드(Deployment/StatefulSet/DaemonSet 등) 단위 통계. 표의 워크로드 행이나 시계열 시리즈를 클릭하면 namespace, 종류, 워크로드 이름과 시간범위가 L2 상세로 전달된다. \"에러 의심\"은 stderr 또는 error/fail/panic 패턴 매치 기준이며, 워크로드별 비중이 평소와 다르면 해당 워크로드를 클릭해 L2에서 원본을 확인한다."
   },
   "transparent": false,
   "id": 1
  },
  {
   "type": "stat",
   "title": "총 로그 수",
   "description": "선택한 namespace/워크로드 종류 필터 기준 로그 건수.",
   "datasource": {
    "type": "grafana-opensearch-datasource",
    "uid": "${datasource}"
   },
   "gridPos": {
    "h": 4,
    "w": 12,
    "x": 0,
    "y": 3
   },
   "targets": [
    {
     "refId": "A",
     "datasource": {
      "type": "grafana-opensearch-datasource",
      "uid": "${datasource}"
     },
     "query": "kubernetes.namespace_name.keyword:($namespace) AND (kubernetes.workload_kind.keyword:($workload_kind))",
     "queryType": "lucene",
     "timeField": "@timestamp",
     "metrics": [
      {
       "id": "1",
       "type": "count"
      }
     ],
     "bucketAggs": [
      {
       "id": "9",
       "type": "date_histogram",
       "field": "@timestamp",
       "settings": {
        "interval": "auto",
        "min_doc_count": "0",
        "trimEdges": "0"
       }
      }
     ]
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "sum"
     ],
     "fields": "",
     "values": false
    },
    "colorMode": "value",
    "graphMode": "area",
    "orientation": "auto",
    "textMode": "auto",
    "justifyMode": "auto"
