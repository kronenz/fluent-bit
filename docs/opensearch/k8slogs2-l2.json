          "type": "grafana-opensearch-datasource",
          "uid": "${datasource}"
        },
        "query": "{\"find\": \"terms\", \"field\": \"level.keyword\", \"size\": 100, \"query\": \"kubernetes.namespace_name.keyword:($namespace)\"}",
        "refresh": 2,
