        "query": "{\"find\": \"terms\", \"field\": \"kubernetes.container_name.keyword\", \"size\": 100, \"query\": \"kubernetes.namespace_name.keyword:($namespace) AND kubernetes.pod_name.keyword:($pod)\"}",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
