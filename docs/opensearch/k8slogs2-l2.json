          "uid": "${datasource}"
        },
        "query": "{\"find\": \"terms\", \"field\": \"kubernetes.host.keyword\", \"size\": 100}",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [],
