    {
      "id": 206,
      "type": "timeseries",
      "title": "로그 볼륨 — 레벨별 (err=빨강·warn=주황·info=초록)",
      "description": "현재 필터의 시간별 로그량을 레벨 색으로 표시(stacked bars). 빨간 구간으로 줌인 후 아래 원본 확인.",
      "datasource": {
        "type": "grafana-opensearch-datasource",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 7
      },
      "targets": [
        {
          "refId": "A",
          "hide": false,
          "datasource": {
            "type": "grafana-opensearch-datasource",
            "uid": "${datasource}"
          },
          "query": "kubernetes.namespace_name.keyword:($namespace) AND (kubernetes.workload_kind.keyword:($workload_kind)) AND (kubernetes.workload_name.keyword:($workload)) AND (kubernetes.pod_name.keyword:($pod)) AND (kubernetes.container_name.keyword:($container)) AND (kubernetes.host.keyword:($node)) AND (level:($level)) AND (${keyword:raw})",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "metrics": [
            {
              "id": "1",
              "type": "count"
            }
          ],
          "bucketAggs": [
            {
              "id": "8",
              "type": "terms",
              "field": "level.keyword",
              "settings": {
                "size": "8",
                "order": "desc",
                "orderBy": "_count",
                "min_doc_count": "1"
              }
            },
            {
              "id": "9",
              "type": "date_histogram",
              "field": "@timestamp",
              "settings": {
                "interval": "auto",
                "min_doc_count": "0",
                "trimEdges": "0"
              }
            }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 35,
            "gradientMode": "opacity",
            "showPoints": "never",
            "pointSize": 4,
            "barAlignment": 0,
            "spanNulls": false,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisLabel": "",
            "axisPlacement": "auto",
            "axisGridShow": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*(err|fatal|crit).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*warn.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(?i).*info.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
