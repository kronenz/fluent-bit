  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "데이터소스",
        "type": "datasource",
        "query": "grafana-opensearch-datasource",
        "current": {},
        "regex": "/^OpenSearch-logs$/",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "namespace",
        "label": "네임스페이스",
        "type": "query",
        "datasource": {
          "type": "grafana-opensearch-datasource",
          "uid": "${datasource}"
        },
        "query": "{\"find\": \"terms\", \"field\": \"kubernetes.namespace_name.keyword\", \"size\": 100}",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [],
        "sort": 1,
        "hide": 0
      },
      {
        "name": "workload_kind",
        "label": "워크로드 종류",
        "type": "query",
        "datasource": {
          "type": "grafana-opensearch-datasource",
          "uid": "${datasource}"
        },
        "query": "{\"find\": \"terms\", \"field\": \"kubernetes.workload_kind.keyword\", \"size\": 100, \"query\": \"kubernetes.namespace_name.keyword:($namespace)\"}",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [],
        "sort": 1,
        "hide": 0
      },
      {
        "name": "workload",
        "label": "워크로드",
        "type": "query",
        "datasource": {
          "type": "grafana-opensearch-datasource",
          "uid": "${datasource}"
        },
        "query": "{\"find\": \"terms\", \"field\": \"kubernetes.workload_name.keyword\", \"size\": 100, \"query\": \"kubernetes.namespace_name.keyword:($namespace) AND kubernetes.workload_kind.keyword:($workload_kind)\"}",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [],
        "sort": 1,
        "hide": 0
      },
