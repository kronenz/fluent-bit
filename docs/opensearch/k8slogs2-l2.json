        "type": "query",
        "datasource": {
          "type": "grafana-opensearch-datasource",
          "uid": "${datasource}"
        },
        "query": "{\"find\": \"terms\", \"field\": \"kubernetes.pod_name.keyword\", \"size\": 100, \"query\": \"kubernetes.namespace_name.keyword:($namespace) AND kubernetes.workload_name.keyword:($workload)\"}",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [],
        "sort": 1,
        "hide": 0
      },
      {
        "name": "container",
